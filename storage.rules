rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /profile_photos/{userId}/{allPaths=**} {
      allow read, write:
      if request.auth != null
      && request.auth.uid == userId;
    }

    match /progress_photos/{userId}/{allPaths=**} {
      allow read, write:
      if request.auth != null
      && request.auth.uid == userId;
    }
  }
}
